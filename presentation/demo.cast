[0.010, "o", "===================================\r\n"]
[0.000, "o", "  CarbonCode CLI Demo\r\n  HLS Pragma Optimization\r\n===================================\r\n"]
[2.007, "o", "\r\n$ python3 main.py info\r\n"]
[1.108, "o", "CarbonCode v0.1\r\nHLS Pragma Optimization with Local Small Language Models\r\n\r\nSupported models (via ollama):\r\n  gemma4:latest    (recommended, 4.5B MoE, PFS=0.883)\r\n  qwen2.5-coder:7b (fast, 7B dense, PFS=0.633)\r\n\r\nKey results:\r\n  PIE C++ optimization: 78% pass@1 (> GPT-4 69%)\r\n  HLS pragma accuracy:  PFS=0.834 (mean)\r\n  Vitis HLS speedup:    up to 63.3x\r\n  Code safety:          100% (post-process merge)\r\n\r\nGitHub: https://github.com/taiwanfifi/CarbonStack\r\n"]
[3.013, "o", "\r\n===================================\r\n  Step 1: Look at the input code\r\n===================================\r\n"]
[1.005, "o", "$ cat carboncode/hls_test/fir_worst.c\r\n"]
[1.010, "o", "// FIR filter - worst pragma config (PIPELINE OFF)\r\n#define N 128\r\n#define TAPS 16\r\n\r\nvoid fir_filter(int input[N], int output[N], int coeffs[TAPS]) {\r\n    #pragma HLS PIPELINE OFF\r\n    #pragma HLS ARRAY_PARTITION variable=coeffs type=cyclic dim=1 factor=1\r\n\r\n    int i, j;\r\n    for (i = 0; i < N; i++) {\r\n        #pragma HLS PIPELINE OFF\r\n        int acc = 0;\r\n        for (j = 0; j < TAPS; j++) {\r\n            #pragma HLS UNROLL factor=1\r\n            int idx = i - j;\r\n            if (idx >= 0)\r\n                acc += input[idx] * coeffs[j];\r\n        }\r\n        output[i] = acc;\r\n    }\r\n}\r\n"]
[3.005, "o", "\r\n===================================\r\n  Step 2: Run CarbonCode optimizer\r\n"]
[0.000, "o", "===================================\r\n"]
[1.006, "o", "$ python3 main.py optimize --input carboncode/hls_test/fir_worst.c --top fir_filter\r\n"]
[1.071, "o", "Input: carboncode/hls_test/fir_worst.c (22 lines)\r\nModel: gemma4:latest\r\nTop function: fir_filter\r\n\r\nCalling LLM... "]
[19.777, "o", "Done! (4 pragmas suggested)\r\n\r\n=== Pragma Changes ===\r\n  - #pragma HLS PIPELINE OFF\r\n  + #pragma HLS ARRAY_PARTITION variable=coeffs type=block dim=1 factor=TAPS\r\n  - #pragma HLS ARRAY_PARTITION variable=coeffs type=cyclic dim=1 factor=1\r\n  + #pragma HLS PIPELINE II=1\r\n  - #pragma HLS PIPELINE OFF\r\n  + #pragma HLS UNROLL\r\n\r\n"]
[0.001, "o", "Output: carboncode/hls_test/fir_worst_opt.c\r\nCode safety: 100% (only pragma lines modified)\r\n"]
[3.015, "o", "\r\n===================================\r\n  Step 3: Check the output\r\n"]
[0.000, "o", "===================================\r\n"]
[1.007, "o", "$ diff carboncode/hls_test/fir_worst.c carboncode/hls_test/fir_worst_opt.c\r\n"]
[1.014, "o", "6,7c6,7\r\n<     #pragma HLS PIPELINE OFF\r\n<     #pragma HLS ARRAY_PARTITION variable=coeffs type=cyclic dim=1 factor=1\r\n---\r\n>     #pragma HLS ARRAY_PARTITION variable=coeffs type=block dim=1 factor=TAPS\r\n>     #pragma HLS PIPELINE II=1\r\n11c11\r\n<         #pragma HLS PIPELINE OFF\r\n---\r\n>         #pragma HLS UNROLL\r\n"]
[3.004, "o", "\r\n===================================\r\n  Result: Baseline → 2050 cycles\r\n  Optimized → 1028 cycles (2x faster)\r\n"]
[0.000, "o", "  Code safety: 100%\r\n===================================\r\n"]
